::Done [nobr]
/*
DONE. Compute SUS score, persist payload, show thank-you.
*/

<<script>>
(function () {
  var ans = State.variables.susAnswers || [];
  var sum = 0;
  for (var i = 0; i < 10; i++) {
    var v = Number(ans[i]) || 0;
    if (i % 2 === 0) {
      sum += (v - 1);
    } else {
      sum += (5 - v);
    }
  }
  var score = sum * 2.5;
  State.variables.susScore = score;

  var payload = {
    endSurvey: {
      favoriteGame: State.variables.favoriteGame,
      funReasons: State.variables.funReasons,
      feeling: State.variables.feeling,
      playAgain: State.variables.playAgain,
      wishOpen: State.variables.wishOpen
    },
    sus: { answers: ans, score: score },
    threeWords: State.variables.threeWords,
    rankFun: State.variables.rankFun,
    rankHealth: State.variables.rankHealth,
    startedAt: State.variables.startedAt,
    completedAt: Date.now()
  };
  try {
    window.localStorage.setItem("cardiocarequest_survey", JSON.stringify(payload));
  } catch (e) {}
  /* CCQ — push the full payload to Flutter so it lands in
     surveys/post_play_v1/responses/{auto} via SurveyHooks.submitResponse.
     localStorage above is just a defensive backup on the device. */
  try {
    if (window.CCQ && typeof window.CCQ.submitResponse === "function") {
      window.CCQ.submitResponse(payload, { pointsEarned: 25 });
    }
  } catch (e) { /* swallow */ }
})();
<</script>>

<div class="phone">
<div class="header"><span>All done</span><span class="header-progress">Complete</span></div>
<div class="progress-track"><div class="progress-fill" style="width: 100%;"></div></div>
<div class="content">

<div class="done-card">
<div class="done-emoji">🎉</div>
<div class="done-headline">Thank you</div>
<p class="done-message">You finished the survey. Your answers are saved on this device.</p>
<div>
<<if $favoriteGame isnot "">><span class="done-stat">Favorite: $favoriteGame</span><</if>>
<span class="done-stat">SUS score: <<print Math.round($susScore)>></span>
</div>
</div>

<p class="narrative center">A researcher will collect your responses from the device.</p>

<div class="spacer"></div>

<a class="btn-primary" onclick="if(window.CCQ){CCQ.goHome();}return false;" href="#">DONE</a>

</div>
</div>

::UserScript [script]

/* CardioCare Quest — auto passage telemetry.
   Fires `passage_entered` for every passage entry via the FlutterBridge.
   Snapshots SugarCube state.variables so researchers see the player's
   path plus key in-game state. Best-effort; swallows errors. */
$(document).on(":passagestart", function (ev) {
  try {
    if (window.CCQ && typeof window.CCQ.telemetry === "function") {
      var snap = {};
      try { Object.assign(snap, SugarCube.State.variables); } catch (e) {}
      CCQ.telemetry("passage_entered", {
        passage: ev.passage.title,
        vars: snap
      });
    }
  } catch (e) { /* swallow */ }
});

