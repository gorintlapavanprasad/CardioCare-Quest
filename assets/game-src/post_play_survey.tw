<<script>>
setTimeout(function () {
  var inputs = [
    document.getElementById("word-1"),
    document.getElementById("word-2"),
    document.getElementById("word-3")
  ];
  inputs.forEach(function (el, i) {
    if (!el) return;
    if (State.variables.threeWords && State.variables.threeWords[i]) {
      el.value = State.variables.threeWords[i];
    }
    if (el.dataset.bound !== "1") {
      el.dataset.bound = "1";
      el.addEventListener("input", function () {
        var arr = (State.variables.threeWords || ["", "", ""]).slice();
        arr[i] = el.value;
        State.variables.threeWords = arr;
      });
    }
  });
  if (setup.bindSpeak) setup.bindSpeak();
}, 0);
<</script>>


