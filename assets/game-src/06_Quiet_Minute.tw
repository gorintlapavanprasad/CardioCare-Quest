:: StoryInit
<<script>>
try {
  var saved = window.localStorage.getItem("quietMinute_history");
  State.variables.history = saved ? JSON.parse(saved) : [];
  var pts = window.localStorage.getItem("quietMinute_points");
  State.variables.totalPoints = pts ? Number(pts) : 0;
} catch (e) {
  State.variables.history = [];
  State.variables.totalPoints = 0;
}
<</script>>
