::Launch Quiet Minute [nobr]
/*
TRAMPOLINE PASSAGE — invoked by the "OPEN QUIET MINUTE" button on the
intro screen. Fires the LAUNCH_GAME bridge call so the Flutter host
pushes Quiet Minute on top of this game, then immediately navigates to
Hub so Vascular Village settles there underneath. When Quiet Minute
ends, the host injects $lastSys/$lastDia into our SugarCube state and
re-renders Hub so the village reflects the fresh reading.
*/
<<run
  if (window.CCQ && typeof window.CCQ.launchGame === "function") {
    window.CCQ.launchGame("quiet_minute");
  }
>>
<<goto "Hub">>


::UserScript [script]

/* CardioCare Quest — auto passage telemetry.
   Fires `passage_entered` for every passage entry via the FlutterBridge.
   Snapshots SugarCube state.variables so researchers see the player's
   path plus key in-game state. Best-effort; swallows errors. */
$(document).on(":passagestart", function (ev) {
  try {
    if (window.CCQ && typeof window.CCQ.telemetry === "function") {
      var snap = {};
      try { Object.assign(snap, SugarCube.State.variables); } catch (e) {}
      CCQ.telemetry("passage_entered", {
        passage: ev.passage.title,
        vars: snap
      });
    }
  } catch (e) { /* swallow */ }
});

