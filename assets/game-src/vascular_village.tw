<<script>>
setTimeout(function () {
  var counter = document.getElementById('plaque-cleared');
  var finish = document.getElementById('plaque-finish');
  var cleared = 0;
  document.querySelectorAll('#plaque-grid .plaque-cell').forEach(function (c) {
    if (c.dataset.bound) return;
    c.dataset.bound = "1";
    if (c.dataset.plaque !== "1") return;
    c.addEventListener('click', function (e) {
      e.preventDefault();
      if (c.classList.contains('cleared')) return;
      c.classList.add('cleared');
      c.textContent = '✓';
      cleared++;
      if (counter) counter.textContent = cleared;
      if (cleared === 8 && finish) finish.style.display = 'block';
    });
  });
}, 0);
<</script>>


