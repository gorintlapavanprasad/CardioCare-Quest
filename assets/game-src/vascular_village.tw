::StoryInit
<<script>>
try {
  var qm = window.localStorage.getItem("quietMinute_history");
  if (qm) {
    var hist = JSON.parse(qm);
    if (hist && hist.length > 0) {
      State.variables.lastSys = Number(hist[0].sys) || 0;
      State.variables.lastDia = Number(hist[0].dia) || 0;
    } else {
      State.variables.lastSys = 0;
      State.variables.lastDia = 0;
    }
  } else {
    State.variables.lastSys = 0;
    State.variables.lastDia = 0;
  }
} catch (e) {
  State.variables.lastSys = 0;
  State.variables.lastDia = 0;
}

try {
  var sav = window.localStorage.getItem("vv_save");
  if (sav) {
    var s = JSON.parse(sav);
    State.variables.totalPoints = Number(s.points) || 0;
    State.variables.voyageDate = s.voyageDate || "";
  } else {
    State.variables.totalPoints = 0;
    State.variables.voyageDate = "";
  }
} catch (e) {
  State.variables.totalPoints = 0;
  State.variables.voyageDate = "";
}

State.variables.heartQuality = "";
State.variables.todayDate = (new Date()).toISOString().slice(0, 10);
<</script>>

::UserStylesheet [stylesheet]
/*
  VASCULAR VILLAGE
  Phone-first, tight Salt-Sludge-style layout.
  Pale viridis-cream page, deep purple-to-teal phone interior.
*/

* { box-sizing: border-box; }

html, body { margin: 0; padding: 0; }

body {
  font-family: "Times New Roman", Times, serif;
  background-color: #f4f1d8;
  padding: 16px 12px;
  font-size: 16px;
  line-height: 1.5;
}

#ui-bar { display: none; }

#story {
  margin: 0 auto;
  max-width: 380px;
  width: 100%;
}

.passage {
  padding: 0;
  margin: 0;
  font-size: 1em;
}

/* Phone frame */
.phone {
  background: linear-gradient(180deg, #440154 0%, #3b528b 50%, #21918c 100%);
  border-radius: 28px;
  overflow: hidden;
  box-shadow: 0 8px 30px rgba(60, 30, 80, 0.22);
  color: #ffffff;
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100%;
  min-height: 640px;
}

.phone *, .phone *::before, .phone *::after {
  word-wrap: break-word;
  overflow-wrap: break-word;
  max-width: 100%;
  box-sizing: border-box;
}

.phone p, .phone div {
  word-wrap: break-word !important;
  overflow-wrap: break-word !important;
  white-space: normal !important;
  max-width: 100% !important;
}

/* Header, tight */
.header {
  padding: 14px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: bold;
  color: #ffffff;
  font-size: 17px;
  background-color: rgba(0,0,0,0.22);
  flex: 0 0 auto;
}
.header-points {
  font-size: 14px;
  font-weight: bold;
  color: #fde725;
}

/* BP card, tight Salt-Sludge style. Sits directly under header. */
.bp-card {
  padding: 14px 20px 12px 20px;
  text-align: center;
}
.bp-label {
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  opacity: 0.85;
  margin-bottom: 8px;
  font-weight: bold;
}
.bp-bar {
  width: 100%;
  height: 6px;
  background-color: rgba(255,255,255,0.18);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 10px;
}
.bp-bar-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.4s ease;
}
.bp-bar-fill.normal { background: linear-gradient(90deg, #5ec962, #fde725); width: 25%; }
.bp-bar-fill.elevated { background: linear-gradient(90deg, #fde725, #f0a020); width: 50%; }
.bp-bar-fill.stage1 { background: linear-gradient(90deg, #f0a020, #d04020); width: 75%; }
.bp-bar-fill.stage2 { background: linear-gradient(90deg, #d04020, #8a1a25); width: 95%; }
.bp-bar-fill.unset { background: rgba(255,255,255,0.25); width: 0%; }

.bp-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 14px;
  margin-bottom: 8px;
}
.bp-numbers {
  font-size: 38px;
  font-weight: bold;
  line-height: 1;
  color: #ffffff;
  letter-spacing: 0.01em;
}
.bp-numbers .slash {
  opacity: 0.4;
  font-weight: normal;
  margin: 0 4px;
}
.bp-units {
  font-size: 12px;
  letter-spacing: 0.08em;
  opacity: 0.65;
}
.bp-zone {
  display: inline-block;
  padding: 4px 14px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: bold;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.zone-normal { background-color: #d6f5d8; color: #1a5a1f; }
.zone-elevated { background-color: #fff0c2; color: #8a5a00; }
.zone-stage1 { background-color: #ffd5b8; color: #8a3a00; }
.zone-stage2 { background-color: #f8c3c8; color: #8a1a25; }
.zone-unset { background-color: rgba(255,255,255,0.18); color: rgba(255,255,255,0.95); }

/* Mascot, tight */
.mascot-wrap {
  text-align: center;
  margin: 6px 0 0 0;
}
.mascot-svg-large { width: 96px; height: 96px; }
.mascot-svg-small { width: 64px; height: 64px; }
.mascot-message {
  text-align: center;
  font-size: 14px;
  font-style: italic;
  opacity: 0.95;
  margin: 4px 22px 12px 22px;
  line-height: 1.45;
  color: #ffffff;
}

/* Content area */
.content {
  padding: 6px 20px 20px 20px;
  display: flex;
  flex-direction: column;
  flex: 1 1 auto;
}
.spacer { flex: 1 1 auto; min-height: 10px; }

/* Typography */
.intro-title {
  text-align: center;
  font-size: 30px;
  font-weight: normal;
  margin: 0 0 14px 0;
  letter-spacing: 0.02em;
  color: #ffffff;
  line-height: 1.2;
}
.section-title {
  font-size: 12px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  opacity: 0.8;
  margin: 4px 0 10px 0;
  color: #ffffff;
  font-weight: bold;
}
.narrative {
  font-size: 17px;
  line-height: 1.55;
  margin: 0 0 12px 0;
  color: #ffffff !important;
}
.narrative.center { text-align: center; }
.narrative:last-of-type { margin-bottom: 0; }
.scene {
  font-size: 17px;
  line-height: 1.55;
  margin: 4px 0 12px 0;
  color: #ffffff;
}
.scene.center { text-align: center; }
.hero-emoji {
  font-size: 80px;
  line-height: 1;
  text-align: center;
  display: block;
  margin: 8px auto 16px auto;
}

/* Quest cards, tight */
.quest-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.quest-card,
.quest-list a.quest-card,
.quest-list a.macro-link,
.quest-list a.link-internal {
  background-color: #ffffff !important;
  color: #1a1a1a !important;
  border: none !important;
  border-radius: 12px !important;
  padding: 12px 14px !important;
  cursor: pointer !important;
  text-decoration: none !important;
  display: flex !important;
  flex-direction: row !important;
  justify-content: flex-start !important;
  align-items: center !important;
  gap: 12px !important;
  text-align: left !important;
  font-family: "Times New Roman", Times, serif !important;
  box-shadow: 0 2px 8px rgba(40, 20, 60, 0.18) !important;
  transition: transform 0.15s ease !important;
  width: 100% !important;
  min-height: 60px !important;
}
.quest-card:hover,
.quest-list a.quest-card:hover,
.quest-list a.macro-link:hover {
  transform: translateY(-1px) !important;
}
.quest-icon {
  font-size: 28px !important;
  line-height: 1 !important;
  flex: 0 0 38px !important;
  text-align: center !important;
}
.quest-text-wrap {
  display: flex !important;
  flex-direction: column !important;
  flex: 1 1 auto !important;
  min-width: 0 !important;
}
.quest-name {
  font-size: 16px !important;
  font-weight: bold !important;
  color: #1a1a1a !important;
  margin: 0 0 2px 0 !important;
  line-height: 1.25 !important;
}
.quest-blurb {
  font-size: 13px !important;
  color: #555 !important;
  margin: 0 !important;
  line-height: 1.4 !important;
  font-weight: normal !important;
}

/* Voyage variant */
.quest-list a.voyage-card {
  background: linear-gradient(135deg, #fde725 0%, #f0a020 100%) !important;
  color: #2a1a4a !important;
}
.quest-list a.voyage-card .quest-name { color: #2a1a4a !important; }
.quest-list a.voyage-card .quest-blurb { color: #4a3a1a !important; }

.voyage-taken {
  background-color: rgba(255,255,255,0.10) !important;
  border-radius: 12px !important;
  padding: 12px 14px !important;
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  gap: 12px !important;
  font-family: "Times New Roman", Times, serif !important;
  min-height: 60px !important;
}
.voyage-taken .quest-icon { color: #5ec962 !important; }
.voyage-taken .quest-name { font-size: 15px !important; font-weight: bold !important; color: rgba(255,255,255,0.9) !important; margin: 0 0 2px 0 !important; line-height: 1.25 !important; }
.voyage-taken .quest-blurb { font-size: 12px !important; color: rgba(255,255,255,0.6) !important; margin: 0 !important; line-height: 1.4 !important; }

/* Quest stage cards inside quests */
.quest-stage {
  background-color: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.16);
  border-radius: 14px;
  padding: 16px 14px;
  margin-bottom: 14px;
}
.quest-stage-instruction {
  text-align: center;
  font-size: 14px;
  opacity: 0.9;
  margin: 0 0 14px 0;
  line-height: 1.5;
}

/* Reallocate Resources */
.alloc-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.alloc-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.alloc-source {
  background-color: #ffffff;
  color: #1a1a1a;
  border-radius: 10px;
  padding: 10px 8px;
  flex: 1;
  text-align: center;
  font-weight: bold;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  min-width: 0;
}
.alloc-source-emoji { font-size: 18px; }
.alloc-arrow { opacity: 0.55; font-size: 16px; flex: 0 0 auto; }
.alloc-target,
.alloc-row a.alloc-target,
.alloc-row a.macro-link {
  background-color: rgba(255,255,255,0.15) !important;
  color: #ffffff !important;
  border: 1px dashed rgba(255,255,255,0.45) !important;
  border-radius: 10px !important;
  padding: 10px 8px !important;
  flex: 1 !important;
  text-align: center !important;
  font-size: 12px !important;
  cursor: pointer !important;
  text-decoration: none !important;
  font-family: "Times New Roman", Times, serif !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-width: 0 !important;
  line-height: 1.3 !important;
}
.alloc-target.matched {
  background-color: #5ec962 !important;
  color: #1a3a0f !important;
  font-weight: bold !important;
  border: 1px solid #5ec962 !important;
}
.alloc-status {
  text-align: center;
  margin-top: 12px;
  font-size: 13px;
  opacity: 0.9;
}

/* Pump the Heart */
.heart-stage {
  text-align: center;
  padding: 14px 0 6px 0;
}
.heart-tap-btn,
.heart-stage a.heart-tap-btn {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  background-color: #fde725 !important;
  color: #2a1a4a !important;
  font-family: "Times New Roman", Times, serif !important;
  border: none !important;
  border-radius: 50% !important;
  width: 130px !important;
  height: 130px !important;
  cursor: pointer !important;
  text-decoration: none !important;
  font-size: 64px !important;
  margin: 0 auto !important;
  line-height: 1 !important;
  transition: transform 0.08s ease !important;
  user-select: none !important;
  box-shadow: 0 0 30px rgba(253, 231, 37, 0.3) !important;
}
.heart-tap-btn.beat,
.heart-stage a.heart-tap-btn.beat {
  transform: scale(0.94) !important;
}
.heart-counter {
  font-size: 28px;
  font-weight: bold;
  margin-top: 16px;
  letter-spacing: 0.04em;
}
.heart-counter-label {
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  opacity: 0.7;
  margin-top: 4px;
}
.heart-rhythm {
  font-size: 14px;
  opacity: 0.92;
  margin-top: 12px;
  text-align: center;
  line-height: 1.5;
  min-height: 22px;
}

/* Clear a Path */
.path-stage {
  background-color: rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 12px;
}
.path-instruction {
  text-align: center;
  font-size: 13px;
  opacity: 0.9;
  margin: 0 0 12px 0;
  line-height: 1.5;
}
.plaque-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-bottom: 10px;
}
.plaque-cell,
.plaque-grid a.plaque-cell,
.plaque-grid a.macro-link {
  background-color: #8a4a30 !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 8px !important;
  aspect-ratio: 1 / 1 !important;
  cursor: pointer !important;
  text-decoration: none !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 20px !important;
  font-family: "Times New Roman", Times, serif !important;
  transition: background-color 0.2s ease !important;
  min-width: 0 !important;
}
.plaque-cell.empty,
.plaque-grid a.plaque-cell.empty {
  background-color: rgba(255,255,255,0.10) !important;
  cursor: default !important;
}
.plaque-cell.cleared,
.plaque-grid a.plaque-cell.cleared {
  background-color: #5ec962 !important;
  cursor: default !important;
  color: #1a3a0f !important;
}
.plaque-counter {
  text-align: center;
  font-size: 13px;
  letter-spacing: 0.04em;
}
.plaque-counter strong {
  color: #fde725;
  font-size: 16px;
  font-weight: bold;
}

/* Stretch */
.stretch-stage {
  text-align: center;
  padding: 24px 0 8px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stretch-prompt-wrap {
  position: relative;
  height: 28px;
  width: 100%;
  margin-bottom: 18px;
  text-align: center;
}
.stretch-prompt {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  font-size: 16px;
  letter-spacing: 0.04em;
}
.stretch-prompt.in { animation: spIn 8s ease-in-out infinite; }
.stretch-prompt.out { animation: spOut 8s ease-in-out infinite; }
@keyframes spIn {
  0% { opacity: 0; }
  5% { opacity: 1; }
  45% { opacity: 1; }
  52% { opacity: 0; }
  100% { opacity: 0; }
}
@keyframes spOut {
  0% { opacity: 0; }
  52% { opacity: 0; }
  58% { opacity: 1; }
  95% { opacity: 1; }
  100% { opacity: 0; }
}
.stretch-circle-wrap {
  width: 200px;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.stretch-circle {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, rgba(253, 231, 37, 0.5), rgba(94, 201, 98, 0.18));
  border: 1px solid rgba(255,255,255,0.5);
  animation: stretchAnim 8s ease-in-out infinite;
  box-shadow: 0 0 50px rgba(253, 231, 37, 0.25);
}
@keyframes stretchAnim {
  0% { width: 80px; height: 80px; opacity: 0.6; }
  45% { width: 180px; height: 180px; opacity: 1; }
  55% { width: 180px; height: 180px; opacity: 1; }
  100% { width: 80px; height: 80px; opacity: 0.6; }
}
.stretch-timer {
  margin: 14px 22px 6px 22px;
  height: 4px;
  background-color: rgba(255,255,255,0.2);
  border-radius: 2px;
  overflow: hidden;
}
.stretch-timer-fill {
  height: 100%;
  background-color: #fde725;
  animation: stretchFill 32s linear forwards;
}
@keyframes stretchFill {
  from { width: 0%; }
  to { width: 100%; }
}
.stretch-timer-text {
  text-align: center;
  font-size: 11px;
  opacity: 0.7;
  letter-spacing: 0.08em;
  margin-bottom: 12px;
}

/* Voyage tour */
.voyage-stage {
  background: linear-gradient(180deg, rgba(253, 231, 37, 0.15) 0%, rgba(94, 201, 98, 0.10) 100%);
  border: 1px solid rgba(253, 231, 37, 0.3);
  border-radius: 14px;
  padding: 18px 16px;
  margin-bottom: 14px;
}
.voyage-step {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
  font-size: 14px;
  line-height: 1.5;
}
.voyage-step:last-child { margin-bottom: 0; }
.voyage-step-icon {
  font-size: 26px;
  flex: 0 0 32px;
  text-align: center;
  line-height: 1;
}

/* Result card */
.result-card {
  background-color: #ffffff;
  border-radius: 14px;
  padding: 22px 18px;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 12px;
}
.result-emoji { font-size: 56px; line-height: 1; margin-bottom: 8px; }
.result-headline {
  font-size: 22px;
  font-weight: bold;
  color: #1a5a1f;
  margin: 0 0 10px 0;
  line-height: 1.25;
}
.result-points {
  display: inline-block;
  background-color: #d6f5d8;
  color: #1a5a1f;
  font-size: 20px;
  font-weight: bold;
  padding: 5px 18px;
  border-radius: 18px;
  margin: 6px 0 14px 0;
}
.result-explain {
  font-size: 15px;
  color: #333;
  line-height: 1.6;
  text-align: left;
  margin: 0;
}

/* Buttons */
.btn-primary,
.phone a.btn-primary,
.phone a.btn-primary.link-internal,
.phone a.btn-primary.macro-link {
  display: block !important;
  width: 100% !important;
  padding: 16px !important;
  background-color: #fde725 !important;
  color: #2a1a4a !important;
  border: none !important;
  border-radius: 12px !important;
  font-weight: bold !important;
  font-size: 14px !important;
  letter-spacing: 0.1em !important;
  text-align: center !important;
  text-decoration: none !important;
  font-family: "Times New Roman", Times, serif !important;
  cursor: pointer !important;
  margin-bottom: 8px !important;
  box-sizing: border-box !important;
}
.btn-primary:last-child,
.phone a.btn-primary:last-child {
  margin-bottom: 0 !important;
}
.btn-secondary,
.phone a.btn-secondary,
.phone a.btn-secondary.link-internal,
.phone a.btn-secondary.macro-link {
  display: block !important;
  width: 100% !important;
  padding: 12px !important;
  background-color: transparent !important;
  border: 1px solid rgba(255,255,255,0.35) !important;
  color: rgba(255,255,255,0.9) !important;
  border-radius: 12px !important;
  font-size: 12px !important;
  letter-spacing: 0.06em !important;
  text-align: center !important;
  text-decoration: none !important;
  font-family: "Times New Roman", Times, serif !important;
  box-sizing: border-box !important;
  margin-bottom: 0 !important;
}

.help-text {
  margin: 12px 0 0 0;
  text-align: center;
  font-size: 12px;
  opacity: 0.7;
  line-height: 1.5;
}

.phone a.link-internal:not(.btn-primary):not(.btn-secondary):not(.quest-card):not(.voyage-card):not(.alloc-target):not(.plaque-cell):not(.heart-tap-btn):not(.macro-link),
.phone a.macro-link:not(.btn-primary):not(.btn-secondary):not(.quest-card):not(.voyage-card):not(.alloc-target):not(.plaque-cell):not(.heart-tap-btn) {
  color: #fde725;
}

@media (min-width: 480px) {
  body { padding: 32px 16px; }
  .phone { min-height: 720px; }
}


::Story innit
<<goto "Welcome">>


::Welcome [nobr]

<div class="phone">
<div class="header"><span>Vascular Village</span><span class="header-points">$totalPoints pts</span></div>
<div class="content">

<div class="mascot-wrap">
<svg class="mascot-svg-large" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id="vvMA" cx="40%" cy="35%" r="65%">
      <stop offset="0%" stop-color="#a5e5a8"/>
      <stop offset="60%" stop-color="#5ec962"/>
      <stop offset="100%" stop-color="#21918c"/>
    </radialGradient>
  </defs>
  <path d="M50 8 C 72 8, 88 22, 90 46 C 92 68, 78 90, 52 92 C 28 94, 10 78, 10 52 C 10 28, 28 8, 50 8 Z" fill="url(#vvMA)" stroke="#1a5a3a" stroke-width="1.5"/>
  <ellipse cx="38" cy="46" rx="5" ry="7" fill="#1a1a1a"/>
  <ellipse cx="62" cy="46" rx="5" ry="7" fill="#1a1a1a"/>
  <ellipse cx="40" cy="44" rx="1.5" ry="2" fill="#ffffff"/>
  <ellipse cx="64" cy="44" rx="1.5" ry="2" fill="#ffffff"/>
  <path d="M40 64 Q 50 72, 60 64" stroke="#1a1a1a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
</svg>
</div>

