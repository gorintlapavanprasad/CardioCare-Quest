<a class="btn-primary" id="alloc-finish" style="display: none;" data-passage="Reallocate Result">FINISH QUEST</a>
<a class="btn-secondary" data-passage="Hub">BACK TO VILLAGE</a>

</div>
</div>

<<script>>
setTimeout(function () {
  var matched = 0;
  var status = document.getElementById('alloc-status');
  var finish = document.getElementById('alloc-finish');
  document.querySelectorAll('.alloc-target').forEach(function (t) {
    if (t.dataset.bound) return;
    t.dataset.bound = "1";
    t.addEventListener('click', function (e) {
      e.preventDefault();
      if (t.classList.contains('matched')) return;
      t.classList.add('matched');
      var label = t.textContent.trim();
      t.textContent = '✓ ' + label;
      matched++;
      if (status) status.textContent = (matched === 3) ? 'All three matched. Nice work.' : (matched + ' of 3 matched');
      if (matched === 3 && finish) finish.style.display = 'block';
    });
  });
}, 0);
<</script>>


