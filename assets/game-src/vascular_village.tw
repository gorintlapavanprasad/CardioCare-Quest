::Quest Pump [nobr]

<div class="phone">
<div class="header"><span>Pump the Heart</span><span class="header-points">$totalPoints pts</span></div>
<div class="content">

<p class="scene center">Tap the heart eight times in a steady rhythm. About one tap per second.</p>

<div class="heart-stage">
<a class="heart-tap-btn" id="heart-btn">💓</a>
<div class="heart-counter" id="heart-count">0 / 8</div>
<div class="heart-counter-label">beats</div>
<div class="heart-rhythm" id="heart-rhythm">Tap to begin.</div>
</div>

<div class="spacer"></div>

<a class="btn-primary" id="heart-finish" style="display: none;" data-passage="Pump Result">FINISH QUEST</a>
<a class="btn-secondary" data-passage="Hub">BACK TO VILLAGE</a>

</div>
</div>

<<script>>
setTimeout(function () {
  var btn = document.getElementById('heart-btn');
  var count = document.getElementById('heart-count');
  var rhythm = document.getElementById('heart-rhythm');
  var finish = document.getElementById('heart-finish');
  if (!btn || btn.dataset.bound) return;
  btn.dataset.bound = "1";
  var taps = [];
  btn.addEventListener('click', function (e) {
    e.preventDefault();
    if (taps.length >= 8) return;
    taps.push(Date.now());
    btn.classList.add('beat');
    setTimeout(function () { btn.classList.remove('beat'); }, 100);
    if (count) count.textContent = taps.length + ' / 8';
    if (taps.length === 1) {
      if (rhythm) rhythm.textContent = 'Keep going.';
    } else if (taps.length < 8) {
      var dt = taps[taps.length - 1] - taps[taps.length - 2];
      if (dt < 600) {
        if (rhythm) rhythm.textContent = 'A little slower.';
      } else if (dt > 1400) {
        if (rhythm) rhythm.textContent = 'A little faster.';
      } else {
        if (rhythm) rhythm.textContent = 'Good rhythm.';
      }
    } else {
      var intervals = [];
      for (var i = 1; i < taps.length; i++) intervals.push(taps[i] - taps[i-1]);
      var avg = intervals.reduce(function (a, b) { return a + b; }, 0) / intervals.length;
      var variance = intervals.reduce(function (a, b) { return a + Math.abs(b - avg); }, 0) / intervals.length;
      var quality = (variance < 200) ? "steady" : (variance < 400) ? "decent" : "shaky";
      State.variables.heartQuality = quality;
      if (rhythm) rhythm.textContent = 'Done. Rhythm was ' + quality + '.';
      if (finish) finish.style.display = 'block';
    }
  });
}, 0);
<</script>>


