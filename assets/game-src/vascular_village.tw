</div>
<<else>>
<div class="bp-row">
<div class="bp-numbers">--<span class="slash">/</span>--</div>
<div class="bp-units">mmHg</div>
</div>
<</if>>
<div class="bp-zone zone-<<print _zk>>"><<print _zl>></div>
</div>

