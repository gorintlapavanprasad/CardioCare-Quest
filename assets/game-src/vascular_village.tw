::Hub [nobr]
/*
HUB. All zone logic inline. No setup functions.
*/
<<set _zk to "unset">>
<<set _zl to "Take a Quiet Minute">>
<<set _msg to "Take a Quiet Minute and the village will see your reading.">>
<<if $lastSys gt 0>>
  <<if $lastSys lt 120 and $lastDia lt 80>>
    <<set _zk to "normal">><<set _zl to "Normal">>
    <<set _msg to "Beautiful reading. The village is calm today.">>
  <<elseif $lastSys lt 130 and $lastDia lt 80>>
    <<set _zk to "elevated">><<set _zl to "Elevated">>
    <<set _msg to "A bit elevated. Let us work on it together today.">>
  <<elseif $lastSys lt 140 and $lastDia lt 90>>
    <<set _zk to "stage1">><<set _zl to "Stage 1">>
    <<set _msg to "Stage 1. The village is here for you. One quest at a time.">>
  <<else>>
    <<set _zk to "stage2">><<set _zl to "Stage 2">>
    <<set _msg to "Stage 2. Talk to your doctor too. The village will help here at home.">>
  <</if>>
<</if>>

<<set _voyageOk to ($voyageDate isnot $todayDate)>>

<div class="phone">
<div class="header"><span>Vascular Village</span><span class="header-points">$totalPoints pts</span></div>

<div class="bp-card">
