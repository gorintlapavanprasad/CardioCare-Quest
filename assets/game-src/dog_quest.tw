:: StoryTitle
Dog Walking


:: StoryData
{
  "ifid": "F6A7B8C9-D0E1-4345-AFAB-456789012345",
  "format": "SugarCube",
  "format-version": "2.37.3",
  "start": "Welcome",
  "zoom": 1
}


:: StoryInit
/*
SYSTEM CODE: runs once at story start. Mirrors the `gameState` object
in the legacy dog_quest.html. Variables:
  $buddyName        — saved companion name (host injects via setBuddyName)
  $questStartTime   — millis when the player picked a difficulty
  $currentDistance  — meters walked so far (driven by host GPS)
  $targetDistance   — chosen quest distance (500 / 1000 / 1500)
  $currentTitle     — quest difficulty title shown in Active Walk
  $currentDesc      — quest difficulty description
  $pointsEarned     — set by onQuestFinished for the celebration scene
  $duration         — formatted duration string ("8 min" / "--")
  $weeklyQuestCount — set by host via setWeeklyQuestCount
*/
<<set $buddyName to "Buddy">>
<<set $questStartTime to 0>>
<<set $currentDistance to 0>>
<<set $targetDistance to 0>>
<<set $currentTitle to "">>
<<set $currentDesc to "">>
<<set $pointsEarned to 0>>
<<set $duration to "--">>
<<set $weeklyQuestCount to 0>>



:: SetupAssets [script]
/* Base64-inlined dog image so the visual works in BOTH twinery.org
   preview AND on device, with no dependency on a relative file path.
   485x400 PNG, ~130KB binary / ~175KB base64. Each scene's <img>
   uses SugarCube's @attribute syntax to pull this in:
     <img @src="setup.dogImgSrc" class="dog-image" ...>  */
setup.dogImgSrc = "data:image/png;base64,";

:: Story Stylesheet [stylesheet]
/*
DOG WALKING — full visual stylesheet ported from dog_quest.html.
Targets the standard SugarCube DOM (#story, .passage) plus per-scene
wrappers (.scene-1 / .scene-2 / .scene-3 / .scene-4) so each passage
can paint its own backdrop.
*/

/* Locally bundled Nunito so the game runs offline at the workshop. */
@font-face {
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url('fonts/Nunito-SemiBold.ttf') format('truetype');
}
@font-face {
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  src: url('fonts/Nunito-Bold.ttf') format('truetype');
}
@font-face {
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  font-style: normal;
  font-weight: 800;
  font-display: swap;
  src: url('fonts/Nunito-ExtraBold.ttf') format('truetype');
}

/* CardioCareQuest viridis palette (canonical across all games):
     #440154  deep purple   — phone gradient stop 1
     #3b528b  blue          — phone gradient stop 2
     #21918c  teal          — phone gradient stop 3
     #5ec962  green          — success bright
     #fde725  yellow         — primary CTA / attention
     #f4f1d8  cream          — page background
   Dog Quest is the most scenic game in the catalog (sky / clouds /
   landscape illustrations), so it does NOT swap its scenic
   illustration colors (sky gradients, cloud purples, character
   shadows). It DOES align the chrome layer with viridis:
     --accent-yellow now uses viridis yellow (#fde725 ← #e4aa24)
     page background now cream (#f4f1d8 ← #c8ccd1)
   --cloud-purple (#9c88b1) is kept because it is both the cloud
   fill AND the soft text accent — replacing it with viridis
   #440154 would turn the clouds deep purple. It sits halfway
   between the viridis deep-purple anchor and white, which is
   close enough for the scenic intent. */
:root {
  --cloud-white: #ffffff;
  --cloud-purple: #9c88b1;
  --accent-yellow: #fde725;
  --text-dark: #3e4a59;
  --progress-bg: #514f35;
  --progress-fill: #786187;
}

body, html {
  margin: 0;
  padding: 0;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  /* Cream backdrop matches the rest of the catalog. On device the
     build-time viewport override flattens .phone so the body
     rarely shows; in Twinery preview it gives the dark phone box
     enough contrast to stand out. */
  background-color: #f4f1d8;
}

/* body padding removed — was 1.5em 0, which left a visible empty
   band above the in-game header on device. Twinery preview still
   reads fine without it (the .phone has its own internal padding). */
body { padding: 0; }

#ui-bar { display: none; }

/* Centered, phone-shaped column in Twinery preview. The build-time
   viewport override forces #story to 100% on device. */
#story {
  margin: 0 auto;
  max-width: 380px;
  padding: 0;
}

.passage { padding: 0; margin: 0; }

/* --- Animations --- */
@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: scale(0.9); }
  50%      { opacity: 1;   transform: scale(1.1); }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideIn {
  from { opacity: 0; transform: translateX(-20px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes popIn {
  from { opacity: 0; transform: scale(0.5); }
  to   { opacity: 1; transform: scale(1); }
}

/* --- Phone box (one per passage) ---
   In twinery.org preview: rounded card, drop shadow, fixed-ish height —
   matches Salt Sludge / Vascular Village / Quiet Minute. On device the
   build-time viewport override (tools/ccq_viewport_override.css)
   strips border-radius / box-shadow / max-width and forces min-height
   to 100vh so the game fills the WebView edge-to-edge. */
.phone {
  width: 100%;
  max-width: 100%;
  min-height: 720px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding-top: 20px;
  border-radius: 32px;
  overflow: hidden;
  box-shadow: 0 8px 30px rgba(0,0,0,0.18);
  position: relative;
}
.phone.scene-1, .phone.scene-2 {
  background: linear-gradient(to bottom, #1e1b2e 0%, #3e6074 40%, #5e8c9c 100%);
}
.phone.scene-3 {
  background: linear-gradient(to bottom, #e0e9ed 0%, #89b1c2 50%, #5e8c9c 100%);
}
.phone.scene-4 {
  background-color: #201c2e;
}


/* --- Scene header (small label + burger menu) --- */
.header {
  width: 100%;
  display: flex;
  /* Was flex-end (clustered both children at the right edge); now
     space-between so the small "EXERCISE" label sits on the left and
     the bridge-injected ≡ burger sits on the right — same pattern as
     the rest of the games. */
  justify-content: space-between;
  align-items: center;
  padding: 4px 18px 0 18px;
  box-sizing: border-box;
  position: relative;
  z-index: 20;
}
.header h1 {
  font-size: 0.78rem;
  font-weight: 700;
  /* Default light-text colour matches the dark gradient on
     scenes 1, 2 and 4. Scene 3 (active walk) uses a LIGHT
     sky-blue gradient from #e0e9ed → #5e8c9c — translucent
     white on light blue is invisible. The .scene-3 override
     below switches to dark text so the "EXERCISE" label and
     the bridge-injected burger icon stay legible against
     the active-walk background. */
  color: rgba(255, 255, 255, 0.7);
  margin: 0;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}
.phone.scene-3 .header h1,
.phone.scene-3 .menu-icon {
  color: rgba(31, 58, 102, 0.85) !important;
}
/* Removed `.menu-icon { display: none }` — the bridge auto-injects
   the burger control and we want it visible here too. */

/* --- Cloud SVG decorations --- */
.cloud { position: absolute; display: flex; justify-content: center; align-items: center; }
.cloud.white { --cloud-fill: var(--cloud-white); z-index: 2; }
.cloud.purple { --cloud-fill: var(--cloud-purple); z-index: 1; }
.cloud-svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; fill: var(--cloud-fill); }
.cloud.white .cloud-svg { filter: drop-shadow(0px 8px 12px rgba(0, 0, 0, 0.15)); }

/* --- Dog assets ---
   On device the bundled dog.png loads. In twinery.org preview the
   relative path resolves to twinery's domain (404) so the <img>'s
   onerror handler swaps to the .dog-emoji fallback — same dimensions,
   service-dog emoji, no broken-image icon. */
/* Responsive dog sizing — clamp(min, preferred, max).
   On a 720px-tall .phone (typical mid-size phone) `28vh` ≈ 201px,
   matching the legacy fixed 200px. On a shorter 600px viewport
   `28vh` ≈ 168px, freeing ~32px for the button stack so the third
   "Beat a boss" tile stops getting clipped at the bottom of the
   screen. The 140px floor keeps the dog readable on tiny test
   devices (phones with viewport < 500px). The 200px ceiling caps
   it on tablets so it doesn't blow up. */
.dog-image {
  width: clamp(140px, 28vh, 200px);
  height: auto;
  z-index: 3;
  position: relative;
}
.dog-emoji {
  display: none;
  width: clamp(140px, 28vh, 200px);
  height: clamp(140px, 28vh, 200px);
  font-size: clamp(112px, 22vh, 160px);
  line-height: clamp(140px, 28vh, 200px);
  text-align: center;
  z-index: 3;
  position: relative;
}
.character-shadow {
  width: clamp(140px, 28vh, 200px);
  height: 14px;
  background-color: #69658a;
  border-radius: 50%;
  margin: -10px auto 0 auto;
  position: relative;
  z-index: 1;
}

/* --- SugarCube link styling (Twee-native buttons) ---
   The <<link>> macro renders as <a class="link-internal">. The Welcome,
   Choose Quest, and Quest Complete passages use SugarCube macros (no
   raw <button>) so navigation works reliably in twinery.org preview.
   Style the anchors to match the legacy HTML's button pixels. */
.footer-btn-link a.link-internal {
  background-color: var(--accent-yellow);
  color: #2a2a2a !important;
  text-decoration: none;
  display: block;
  width: 90%;
  margin: 0 auto 25px auto;
  padding: 18px;
  border-radius: 35px;
  text-align: center;
  font-weight: 800;
  font-size: 1.15rem;
  cursor: pointer;
  box-shadow: 0 5px 0px #c6942a;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  z-index: 10;
  position: relative;
}
.footer-btn-link a.link-internal:active {
  transform: translateY(3px);
  box-shadow: 0 2px 0px #c6942a;
}

.button-stack a.link-internal {
  background-color: var(--accent-yellow);
  color: #2a2a2a !important;
  text-decoration: none;
  width: 100%;
  /* 14px vertical / 16px horizontal — earlier 12px / 10px felt
     cramped, especially with the desc line wrapping on narrow
     phones. Combined with min-height below, gives every quest
     tile a 64px tap target which matches accessibility guidance
     for elderly users. */
  padding: 14px 16px;
  min-height: 64px;
  border-radius: 25px;
  text-align: center;
  cursor: pointer;
  box-shadow: 0 4px 0px #b88616;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  box-sizing: border-box;
}
.button-stack a.link-internal:active {
  transform: translateY(4px);
  box-shadow: 0 0px 0px #b88616;
}
/* Bumped from 0.75rem to 0.92rem (~14.7px) — the smaller size
   was illegible for the 60+ low-vision target audience. Title
   stays at 1.15rem; gap between the two lines bumped to 4px so
   neither runs into the other. */
.button-stack a.link-internal .quest-title {
  font-weight: 800;
  font-size: 1.15rem;
  line-height: 1.25;
  margin-bottom: 4px;
}
.button-stack a.link-internal .quest-desc {
  font-weight: 700;
  font-size: 0.92rem;
  line-height: 1.35;
  opacity: 0.9;
}

/* Celebration scene buttons — primary (Do Another Quest) is the
   yellow accent that matches BEGIN on Welcome; secondary (Return to
   Dashboard) is an outlined button with white border so it reads
   clearly on the dark purple celebration background. The earlier
   styling layered backgrounds on both the wrapper div AND the inner
   `a.link-internal` and used a low-contrast purple border, which
   came out faded and double-padded on device. We now style ONLY the
   `<<link>>` macro's anchor — single source of truth, predictable
   tap target. */
.celebration-actions a.link-internal {
  display: block;
  text-decoration: none;
  text-align: center;
  font-size: 16px;
  font-weight: 800;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
  cursor: pointer;
  border-radius: 16px;
  padding: 18px;
  letter-spacing: 0.04em;
  transition: transform 0.1s;
}
.celebration-actions a.link-internal:active {
  transform: translateY(2px);
}
.celebration-actions .btn-another-quest a.link-internal {
  background: var(--accent-yellow);
  color: #2a2a2a !important;
  border: none;
  box-shadow: 0 5px 0 #c6942a;
}
.celebration-actions .btn-another-quest a.link-internal:active {
  box-shadow: 0 2px 0 #c6942a;
}
.celebration-actions .btn-final-home a.link-internal {
  background: transparent;
  color: var(--cloud-white) !important;
  border: 2px solid rgba(255, 255, 255, 0.6);
  padding: 16px;
}

/* --- Twinery preview-only debug link ---
   Active Walk has no in-game completion button — on device the host's
   GPS watchdog fires `onQuestFinished` once distance hits the target.
   This little link gives Twinery preview a way to advance to the
   celebration scene manually so authors can review it. It's hidden on
   device by an `<<if typeof window.CCQ === "undefined">>` gate. */
.preview-only-link {
  margin-top: 20px;
  margin-bottom: 20px;
  width: 90%;
  text-align: center;
}
.preview-only-link a.link-internal {
  color: rgba(60, 60, 60, 0.55) !important;
  font-size: 0.75rem;
  font-style: italic;
  text-decoration: underline;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
}

/* --- Scene 1: intro --- */
.scene-1 .subtitle {
  color: #8acfe5;
  font-weight: 800;
  font-size: 1.15rem;
  text-align: center;
  margin: 15px 0 10px 0;
  padding: 0 10px;
}
.scene-1 .cloud-area { flex-grow: 1; width: 100%; position: relative; }
.scene-1 .cloud-text {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 0.78rem;
  line-height: 1.25;
  color: var(--text-dark);
  width: 70%;
  padding: 0 4px;
  box-sizing: border-box;
  margin-top: -5px;
}
.c1 { top: 3%; left: 3%; width: 180px; height: 130px; }
.c2 { top: 8%; right: -5%; width: 230px; height: 150px; opacity: 0.9; }
.c3 { top: 28%; left: 16%; width: 270px; height: 190px; }
.c4 { top: 48%; left: -10%; width: 190px; height: 130px; opacity: 0.9; }
.c5 { top: 58%; right: -2%; width: 210px; height: 150px; }
.c3::after {
  content: '';
  position: absolute;
  bottom: -20px;
  left: 55%;
  height: 30px;
  border-left: 3px dashed var(--accent-yellow);
  z-index: 0;
}
.scene-1 .character-container {
  margin-bottom: 30px;
  text-align: center;
  position: relative;
}

/* Yellow footer button — used for primary actions on scene 1 */
.footer-btn {
  background-color: var(--accent-yellow);
  width: 90%;
  padding: 18px;
  border-radius: 35px;
  text-align: center;
  font-weight: 800;
  font-size: 1.15rem;
  color: #2a2a2a;
  margin-bottom: 25px;
  cursor: pointer;
  box-shadow: 0 5px 0px #c6942a;
  border: none;
  z-index: 10;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
}
.footer-btn:active { transform: translateY(3px); box-shadow: 0 2px 0px #c6942a; }

/* --- Scene 2: quest picker --- */
.scene-2 .subtitle {
  color: #559db8;
  font-weight: 800;
  font-size: 1rem;
  text-align: center;
  margin: 15px 0 10px 0;
  padding: 0 20px;
  line-height: 1.4;
  z-index: 10;
  position: relative;
}
.scene-2 .cloud-area {
  position: absolute;
  /* Was top: 16% — that put the cloud top at ~115px on a 720px
     viewport, which on a real device with a status-bar safe inset
     and 2-line subtitle ("Regular exercise can help lower blood
     pressure and improve heart health.") had the cloud's top edge
     visually touching the subtitle's last line. Pushed to 24% so
     there's a clear gap between subtitle and cloud bubble — the
     subtitle is the instruction, the cloud is the heading-of-
     options below it; they read as separate UI blocks now. */
  top: 24%;
  left: 0;
  width: 100%;
  height: 22%;
  z-index: 1;
}
.scene-2 .cloud-text {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text-dark);
  width: 70%;
  line-height: 1.2;
}
/* Side purple decoration clouds — kept off-canvas left for atmosphere. */
.c-purple-1 { top: 30%; left: -28%; width: 200px; height: 140px; opacity: 0.8; }
.c-purple-2 { top: 95%; left: -32%; width: 170px; height: 110px; opacity: 0.8; }
/* Main white speech bubble — sized + positioned so it sits ABOVE the
   dog instead of behind it. Earlier 300x200 at top:8% put the cloud's
   center at the same y as the dog body, hiding the prompt text. */
.c-white-main { top: 0%; left: 50%; transform: translateX(-50%); width: 240px; height: 130px; }

.scene-2 .character-container {
  margin-top: auto;
  margin-bottom: 16px;
  text-align: center;
  width: 100%;
  position: relative;
  z-index: 5;
}

/* Short-viewport tweak for compact phones where the dog image,
   three quest buttons, and breathing space don't all fit on
   720px. Tightens vertical rhythms so the "Beat a boss" tile
   isn't visually clipped at the bottom edge. */
@media (max-height: 680px) {
  .scene-2 .character-container { margin-bottom: 10px; }
  .button-stack { gap: 10px; margin-bottom: 12px; }
  .button-stack a.link-internal {
    padding: 12px 14px;
    min-height: 60px;
  }
  .button-stack a.link-internal .quest-title { font-size: 1.05rem; }
  .button-stack a.link-internal .quest-desc { font-size: 0.85rem; }
}

.button-stack {
  /* 92% width gives a few extra px of breathing room on the
     sides versus the previous 90% — visually more aligned with
     the subtitle / cloud / character above. */
  width: 92%;
  max-width: 360px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 20px;
  z-index: 10;
}
.quest-btn {
  background-color: var(--accent-yellow);
  width: 100%;
  padding: 12px 10px;
  border-radius: 25px;
  text-align: center;
  color: #2a2a2a;
  cursor: pointer;
  box-shadow: 0 4px 0px #b88616;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s;
  font-family: 'Atkinson Hyperlegible', system-ui, -apple-system, "Segoe UI", sans-serif;
}
.quest-btn:active { transform: translateY(4px); box-shadow: 0 0px 0px #b88616; }
.quest-title { font-weight: 800; font-size: 1.15rem; margin-bottom: 2px; }
.quest-desc { font-weight: 700; font-size: 0.75rem; opacity: 0.9; }

/* --- Scene 3: active walk --- */
.scene-3 .stats-text {
  color: #5998cc;
  font-weight: 800;
  font-size: 0.9rem;
  text-align: center;
  margin: 15px 0 5px 0;
  z-index: 10;
}
.scene-3 .character-container {
  margin-top: 10px;
  margin-bottom: 15px;
  text-align: center;
  width: 100%;
}
.scene-3 .character-shadow { background-color: #798b9e; }
.scene-3 .dog-image { width: 180px; }

.active-quest {
  background-color: var(--accent-yellow);
  width: 90%;
  padding: 12px 10px;
  border-radius: 30px;
  text-align: center;
  color: #2a2a2a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 15px;
}
.active-quest .quest-desc { font-weight: 800; }

.progress-container {
  width: 90%;
  height: 55px;
  background-color: var(--progress-bg);
  border-radius: 30px;
  position: relative;
  overflow: hidden;
  margin-bottom: 25px;
  box-shadow: inset 0 2px 5px rgba(0,0,0,0.2);
}
.progress-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  width: 0%;
  background-color: var(--progress-fill);
  border-radius: 30px;
  transition: width 0.4s ease-out;
}
.progress-text-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20px;
  box-sizing: border-box;
  z-index: 2;
}
.progress-left { color: white; font-weight: 700; font-size: 1rem; display: flex; gap: 15px; align-items: center; }
.progress-percent { font-weight: 800; font-size: 1.1rem; }
.progress-right { color: white; text-align: right; line-height: 1.1; }
.progress-right .number { font-weight: 800; font-size: 0.85rem; display: block; }
.progress-right .label  { font-weight: 600; font-size: 0.7rem; opacity: 0.9; }

.info-section { width: 90%; margin-top: 5px; }
.info-title {
  color: #2c3e50;
  font-weight: 800;
  font-size: 1rem;
  text-align: center;
  margin-bottom: 15px;
}
.info-list { list-style: none; padding: 0 0 0 25px; margin: 0; display: flex; flex-direction: column; gap: 15px; }
.info-list li {
  color: #2c3e50;
  font-weight: 700;
  font-size: 0.95rem;
  display: flex;
  align-items: center;
  gap: 12px;
}
.info-list li::before {
  content: '✓';
  display: inline-block;
  width: 14px;
  height: 14px;
  font-size: 1.2rem;
  line-height: 1;
  text-align: center;
  color: var(--progress-fill);
  flex-shrink: 0;
}

/* --- Scene 4: celebration --- */
.scene-4 .celebration-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 40px 20px 60px;
  width: 100%;
  box-sizing: border-box;
  flex-grow: 1;
}
.celebration-emoji { font-size: 72px; margin-bottom: 20px; animation: popIn 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
.celebration-title {
  color: var(--cloud-white);
  font-size: 36px;
  margin: 0 0 12px 0;
  font-weight: 800;
  text-align: center;
  animation: slideIn 0.5s ease-out;
}
.celebration-message {
  color: var(--cloud-purple);
  font-size: 18px;
  margin: 0 0 40px 0;
  line-height: 1.6;
  text-align: center;
  max-width: 90%;
  animation: fadeUp 0.6s ease-out 0.1s both;
}
.celebration-message .name-highlight { color: var(--accent-yellow); font-weight: 800; }
.celebration-stats {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 28px 24px;
  margin-bottom: 40px;
  width: 90%;
  max-width: 400px;
  box-sizing: border-box;
  animation: fadeUp 0.6s ease-out 0.2s both;
}
.celebration-points-row {
  text-align: center;
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.celebration-points-label {
  font-size: 14px;
  color: var(--cloud-purple);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 12px;
  font-weight: 700;
}
.celebration-points-value {
  font-size: 56px;
  font-weight: 900;
  color: var(--accent-yellow);
  line-height: 1;
}
.celebration-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.celebration-grid .label {
  color: var(--cloud-purple);
  font-size: 12px;
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 8px;
  text-align: center;
}
.celebration-grid .value {
  color: var(--cloud-white);
  font-size: 24px;
  font-weight: 800;
  text-align: center;
}
.celebration-tip {
  background: rgba(156, 136, 177, 0.15);
  border-left: 4px solid var(--cloud-purple);
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 40px;
  width: 90%;
  max-width: 400px;
  box-sizing: border-box;
  color: var(--cloud-purple);
  font-size: 14px;
  font-weight: 600;
  line-height: 1.6;
  animation: fadeUp 0.6s ease-out 0.3s both;
}
.celebration-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 90%;
  max-width: 400px;
  animation: fadeUp 0.6s ease-out 0.4s both;
}
/* Wrapper divs — no styling; visuals live on the inner
   `a.link-internal` (see `.celebration-actions a.link-internal`
   block above). The wrapper is purely a layout slot for the
   `<<link>>` macro's anchor. */
.btn-another-quest, .btn-final-home {
  display: block;
}


:: UserScript [script]
/*
WINDOW-LEVEL CALLBACKS — these are how the Flutter `TwineGameHost`
talks INTO this game. The host calls them via `controller.runJavaScript`
on every meaningful event (game open, GPS fix, walk completion, app
relaunch with an in-progress walk). Defining them on `window` keeps
them available globally regardless of which passage the player is on.

In twinery.org preview, the host is absent — these still work as state
mutators + DOM updaters, they just never get called by anyone.

Telemetry hook (bottom of this file) fires `passage_entered` on every
SugarCube `:passagestart` event so researchers see the exact path the
player took plus the in-game state at each step. Same convention as
the other CardioCare Quest games.
*/

/* Robust passage navigation that survives every quirk we've hit. The
   host's `_controller.runJavaScript(...)` calls land in an arbitrary
   spot in SugarCube's render pipeline, and a synchronous Engine.play()
   from there can silently no-op. The setTimeout(0) defers the
   navigation to the next event-loop tick, after any in-flight state
   updates have settled. The SugarCube.Engine fallback covers cases
   where window.Engine isn't aliased. */
function ccqGoto(passage) {
  if (!passage) return;
  setTimeout(function () {
    try {
      if (window.SugarCube && SugarCube.Engine &&
          typeof SugarCube.Engine.play === "function") {
        SugarCube.Engine.play(passage);
        return;
      }
    } catch (e) { /* fall through */ }
    try {
      if (window.Engine && typeof Engine.play === "function") {
        Engine.play(passage);
      }
    } catch (e) { /* swallow */ }
  }, 0);
}

/* Map the legacy showPage(sceneId) calls onto SugarCube passages so the
   host's existing `runJavaScript("showPage('scene1');")` keeps working. */
window.showPage = function (pageId) {
  var map = {
    "scene1": "Welcome",
    "scene2": "Choose Quest",
    "scene3": "Active Walk",
    "scene4": "Quest Complete"
  };
  ccqGoto(map[pageId]);
};

/* Restore the saved companion name from the user profile. */
window.setBuddyName = function (name) {
  if (typeof name !== "string" || !name.trim()) return;
  try {
    if (window.SugarCube && SugarCube.State) {
      SugarCube.State.variables.buddyName = name.trim();
    }
  } catch (e) { /* swallow */ }
};

/* Push the weekly count into the stats line on Active Walk. */
window.setWeeklyQuestCount = function (n) {
  var num = Number(n) || 0;
  try {
    if (window.SugarCube && SugarCube.State) {
      SugarCube.State.variables.weeklyQuestCount = num;
    }
  } catch (e) { /* swallow */ }
  var el = document.getElementById("quests-completed-text");
  if (el) {
    el.innerText = num + " quest" + (num === 1 ? "" : "s") +
                   " completed so far this week!";
  }
};

/* Periodic GPS update from the host. Updates DOM directly — re-rendering
   the whole passage at 5 Hz would jank the animation, plus the host's
   incoming distance is already mid-walk state, not a passage transition. */
window.updateGameProgress = function (currentDistance, targetDistance) {
  if (currentDistance < 0) currentDistance = 0;
  if (targetDistance > 0 && currentDistance > targetDistance) {
    currentDistance = targetDistance;
  }
  var pct = (targetDistance > 0)
    ? Math.floor((currentDistance / targetDistance) * 100) : 0;
  var remaining = Math.floor(Math.max(0, targetDistance - currentDistance));

  try {
    if (window.SugarCube && SugarCube.State) {
      SugarCube.State.variables.currentDistance = currentDistance;
      SugarCube.State.variables.targetDistance = targetDistance;
    }
  } catch (e) { /* swallow */ }

  var fillEl = document.getElementById("progress-bar-fill");
  var pctEl  = document.getElementById("progress-percent-text");
  var remEl  = document.getElementById("progress-remaining-text");
  if (fillEl) fillEl.style.width = pct + "%";
  if (pctEl)  pctEl.innerText = pct + "%";
  if (remEl)  remEl.innerText = remaining + "m";
};

/* Restore an in-progress walk on app relaunch. The host calls this if
   it found `ongoingDistance` / `ongoingTarget` in the gameStates doc.
   We hop straight to the Active Walk passage with the right title +
   description, then push the saved progress into the DOM. */
window.resumeWalk = function (currentDistance, targetDistance) {
  var rounded = Math.round(targetDistance);
  var title = "Dog Walk";
  var desc  = "Resuming your walk in progress.";
  if (rounded === 500)  { title = "Keep going";          desc = "EASY- Quick walk- 500 steps- 30 pts"; }
  else if (rounded === 1000) { title = "Travel to a village"; desc = "MEDIUM- Maintenance walk- 1000 steps- 60 pts"; }
  else if (rounded === 1500) { title = "Beat a boss!!";       desc = "HARD- Challenge yourself- 1500 steps- 100 pts"; }

  try {
    if (window.SugarCube && SugarCube.State) {
      SugarCube.State.variables.currentDistance = currentDistance;
      SugarCube.State.variables.targetDistance = targetDistance;
      SugarCube.State.variables.currentTitle = title;
      SugarCube.State.variables.currentDesc = desc;
    }
  } catch (e) { /* swallow */ }

  ccqGoto("Active Walk");
  /* Defer DOM update until after the passage renders. */
  setTimeout(function () {
    window.updateGameProgress(currentDistance, targetDistance);
  }, 100);
};

/* Called by the host once the GPS-driven distance threshold is hit.
   Computes a duration string and routes to the celebration scene with
   the awarded points. */
window.onQuestFinished = function (pointsGained) {
  var pts = Number(pointsGained) || 0;
  var startTime = 0;
  var currentDist = 0;
  var buddy = "your companion";
  try {
    if (window.SugarCube && SugarCube.State) {
      startTime = Number(SugarCube.State.variables.questStartTime) || 0;
      currentDist = Number(SugarCube.State.variables.currentDistance) || 0;
      buddy = SugarCube.State.variables.buddyName || buddy;
    }
  } catch (e) { /* swallow */ }

  var duration = "--";
  if (startTime > 0) {
    var ms = Date.now() - startTime;
    var mins = Math.round(ms / 60000);
    duration = mins + " min";
  }

  try {
    if (window.SugarCube && SugarCube.State) {
      SugarCube.State.variables.pointsEarned = pts;
      SugarCube.State.variables.duration = duration;
    }
  } catch (e) { /* swallow */ }

  ccqGoto("Quest Complete");
};

/* Restore the player's serialized SugarCube state from the host's
   gameStates.gameState field. Free-form payload — we don't introspect. */
window.hydrateState = function (json) {
  try {
    var data = JSON.parse(json);
    if (data && window.SugarCube && SugarCube.State) {
      Object.assign(SugarCube.State.variables, data);
    }
  } catch (e) { /* swallow */ }
};

/* Auto passage telemetry — fires `passage_entered` for every passage
   entry via the FlutterBridge, snapshotting the in-game state. Same
   convention as the other CardioCare Quest games. */
$(document).on(":passagestart", function (ev) {
  try {
    if (window.CCQ && typeof window.CCQ.telemetry === "function") {
      var snap = {};
      try { Object.assign(snap, SugarCube.State.variables); } catch (e) {}
      CCQ.telemetry("passage_entered", {
        passage: ev.passage.title,
        vars: snap
      });
    }
  } catch (e) { /* swallow */ }
});


:: Welcome [nobr]
/*
SCENE 1: introduction. Mirrors `#scene1` in dog_quest.html.
Cloud decorations + dog image + "Step outside…" yellow button.
The button uses an inline onclick (instead of <<link>>) so the visual
matches the legacy HTML's .footer-btn pixel-for-pixel.
*/
<div class="phone scene-1">
  <header class="header">
    <h1>Exercise</h1>
    <span class="menu-icon">≡</span>
  </header>
  <div class="subtitle">Let's work towards healthy blood pressure today!</div>

  <div class="cloud-area">
    <div class="cloud white c1"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg><div class="cloud-text">Complete Quests based on steps</div></div>
    <div class="cloud white c3"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg><div class="cloud-text">Bring along a furry team member to help complete them</div></div>
    <div class="cloud white c5"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg><div class="cloud-text">Earn rewards to customize your dog's avatar</div></div>
    <div class="cloud purple c2"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg></div>
    <div class="cloud purple c4"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg></div>
  </div>

  <div class="character-container">
<img @src="setup.dogImgSrc" class="dog-image" alt="Quest Dog">
  </div>

  <div class="footer-btn-link">
    <<link "Step outside for a walk with a friend!">>
      <<goto "Choose Quest">>
    <</link>>
  </div>
</div>

/* Inline SVG defs — referenced by every cloud's <use href="#cloud-shape">.
   Lives in every scene that uses clouds so the symbol is always in scope. */
<svg style="display: none;">
  <defs>
    <g id="cloud-shape">
      <circle cx="35" cy="55" r="20" />
      <circle cx="65" cy="35" r="32" />
      <circle cx="105" cy="50" r="24" />
      <circle cx="50" cy="75" r="18" />
      <circle cx="90" cy="70" r="22" />
      <circle cx="70" cy="60" r="25" />
    </g>
  </defs>
</svg>


:: Choose Quest [nobr]
/*
SCENE 2: pick a difficulty. Mirrors `#scene2` in dog_quest.html.
Each yellow button sets state vars + calls CCQ.startTracking($targetDistance)
+ navigates to Active Walk. Twinery preview no-ops the bridge call.
*/
<div class="phone scene-2">
  <header class="header">
    <h1>Exercise</h1>
    <span class="menu-icon">≡</span>
  </header>
  <div class="subtitle">Regular exercise can help lower blood pressure<br>and improve heart health.</div>

  <div class="cloud-area">
    <div class="cloud purple c-purple-1"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg></div>
    <div class="cloud purple c-purple-2"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg></div>
    <div class="cloud white c-white-main"><svg class="cloud-svg" viewBox="0 0 140 100" preserveAspectRatio="none"><use href="#cloud-shape" /></svg><div class="cloud-text">Choose your quest for today</div></div>
  </div>

  <div class="character-container">
<img @src="setup.dogImgSrc" class="dog-image" alt="Quest Dog">
    <div class="character-shadow"></div>
  </div>

  <div class="button-stack">
    <<link '<div class="quest-title">Keep going</div><div class="quest-desc">EASY- Quick walk- 500 steps- 30 pts</div>'>>
      <<set $targetDistance to 500>>
      <<set $currentTitle to "Keep going">>
      <<set $currentDesc to "EASY- Quick walk- 500 steps- 30 pts">>
      <<set $questStartTime to (new Date()).getTime()>>
      <<set $currentDistance to 0>>
      <<run if (window.CCQ && typeof window.CCQ.startTracking === "function") { window.CCQ.startTracking(500); }>>
      <<goto "Active Walk">>
    <</link>>
    <<link '<div class="quest-title">Travel to a village</div><div class="quest-desc">MEDIUM- Maintenance walk- 1000 steps- 60 pts</div>'>>
      <<set $targetDistance to 1000>>
      <<set $currentTitle to "Travel to a village">>
      <<set $currentDesc to "MEDIUM- Maintenance walk- 1000 steps- 60 pts">>
      <<set $questStartTime to (new Date()).getTime()>>
      <<set $currentDistance to 0>>
      <<run if (window.CCQ && typeof window.CCQ.startTracking === "function") { window.CCQ.startTracking(1000); }>>
      <<goto "Active Walk">>
    <</link>>
    <<link '<div class="quest-title">Beat a boss!!</div><div class="quest-desc">HARD- Challenge yourself- 1500 steps- 100 pts</div>'>>
      <<set $targetDistance to 1500>>
      <<set $currentTitle to "Beat a boss!!">>
      <<set $currentDesc to "HARD- Challenge yourself- 1500 steps- 100 pts">>
      <<set $questStartTime to (new Date()).getTime()>>
      <<set $currentDistance to 0>>
      <<run if (window.CCQ && typeof window.CCQ.startTracking === "function") { window.CCQ.startTracking(1500); }>>
      <<goto "Active Walk">>
    <</link>>
  </div>
</div>

/* Cloud SVG def repeated so this passage stands alone. */
<svg style="display: none;">
  <defs>
    <g id="cloud-shape">
      <circle cx="35" cy="55" r="20" />
      <circle cx="65" cy="35" r="32" />
      <circle cx="105" cy="50" r="24" />
      <circle cx="50" cy="75" r="18" />
      <circle cx="90" cy="70" r="22" />
      <circle cx="70" cy="60" r="25" />
    </g>
  </defs>
</svg>


:: Active Walk [nobr]
/*
SCENE 3: in-progress quest. Mirrors `#scene3` in dog_quest.html.
The DOM ids (#progress-bar-fill, #progress-percent-text,
#progress-remaining-text, #quests-completed-text, #active-title,
#active-desc) are preserved so the host's runJavaScript callbacks
(updateGameProgress / setWeeklyQuestCount / resumeWalk) just work.
*/
<div class="phone scene-3">
  <header class="header">
    <h1>Exercise</h1>
    <span class="menu-icon">≡</span>
  </header>
  <div class="stats-text" id="quests-completed-text">$weeklyQuestCount quests completed so far this week!</div>

  <div class="character-container">
<img @src="setup.dogImgSrc" class="dog-image" alt="Quest Dog">
  </div>

  <div class="active-quest">
    <div class="quest-title" id="active-title">$currentTitle</div>
    <div class="quest-desc"  id="active-desc">$currentDesc</div>
  </div>

  <div class="progress-container">
    <div class="progress-fill" id="progress-bar-fill"></div>
    <div class="progress-text-overlay">
      <div class="progress-left">
        <span>Progress</span>
        <span class="progress-percent" id="progress-percent-text">0%</span>
      </div>
      <div class="progress-right">
        <span class="number" id="progress-remaining-text">--</span>
        <span class="label">Distance remaining</span>
      </div>
    </div>
  </div>

  <div class="info-section">
    <div class="info-title">How does exercise help with blood pressure?</div>
    <ul class="info-list">
      <li>Improves circulation</li>
      <li>Reduces Stress</li>
      <li>Helps maintain healthy weight</li>
    </ul>
  </div>

  /* Preview-only manual completion. Hidden on device — there, the host's
     GPS watchdog fires `onQuestFinished` once distance hits the target. */
  <<if typeof window.CCQ === "undefined">>
  <div class="preview-only-link">
    <<link "Mark walk complete (preview only)">>
      <<set $currentDistance to $targetDistance>>
      <<set $duration to "5 min">>
      <<if $targetDistance lte 500>>
        <<set $pointsEarned to 30>>
      <<elseif $targetDistance lte 1000>>
        <<set $pointsEarned to 60>>
      <<else>>
        <<set $pointsEarned to 100>>
      <</if>>
      <<goto "Quest Complete">>
    <</link>>
  </div>
  <</if>>
</div>


:: Quest Complete [nobr]
/*
SCENE 4: celebration. Mirrors `#scene4` in dog_quest.html.
"Do Another Quest" loops back to Welcome (state stays — host can
mint a new movement session on the next CCQ.startTracking call).
"Return to Dashboard" routes through Central Hub which fires
CCQ.goHome() → host pops the Flutter route.
*/
<div class="phone scene-4">
  <div class="celebration-wrap">
    <div class="celebration-emoji">🎉</div>
    <h1 class="celebration-title">Amazing Work!</h1>
    <p class="celebration-message">
      You and <span class="name-highlight" id="completion-dog-name">$buddyName</span> completed the quest!
    </p>

    <div class="celebration-stats">
      <div class="celebration-points-row">
        <div class="celebration-points-label">Points Earned</div>
        <div class="celebration-points-value" id="final-points-text">+$pointsEarned points</div>
      </div>
      <div class="celebration-grid">
        <div>
          <div class="label">Distance</div>
          <div class="value" id="completion-distance"><<print Math.round($currentDistance)>>m</div>
        </div>
        <div>
          <div class="label">Duration</div>
          <div class="value" id="completion-time">$duration</div>
        </div>
      </div>
    </div>

    <div class="celebration-tip">
      💓 <strong>Great for your heart!</strong><br>
      Regular walks help lower blood pressure and reduce cardiovascular risk over time.
    </div>

    <div class="celebration-actions">
      <div class="btn-another-quest">
        <<link "Do Another Quest">>
          <<goto "Welcome">>
        <</link>>
      </div>
      <div class="btn-final-home">
        <<link "Return to Dashboard">>
          <<run
            try {
              if (window.CCQ && typeof window.CCQ.goHome === "function") {
                window.CCQ.goHome();
              }
            } catch (e) { /* swallow */ }
          >>
        <</link>>
      </div>
    </div>
  </div>
</div>


:: Central Hub
/*
EXIT HATCH. Visiting this passage fires the CCQ.goHome() bridge call
which tells the Flutter host to pop the WebView's route and return to
the dashboard. There's no UI here on purpose — the host pops before
the player sees anything. In twinery.org preview, the bridge no-ops
and the player sees just the loading text below.
*/
<<run if (window.CCQ && typeof window.CCQ.goHome === "function") { window.CCQ.goHome(); }>>

<div class="phone scene-1">
  <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100vh;">
    <div style="font-size:72px; animation: pulse 1.5s infinite;">🐾</div>
    <div style="font-family:'Atkinson Hyperlegible',system-ui,-apple-system,"Segoe UI",sans-serif; font-weight:700; color:#9c88b1; margin-top:24px; font-size:18px;">
      Returning to dashboard…
    </div>
  </div>
</div>
